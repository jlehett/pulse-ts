# Terraform state (contains secrets and resource details)
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# Build artifacts
.build/

# Crash logs
crash.log
crash.*.log

# Override files (used for local-only overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
