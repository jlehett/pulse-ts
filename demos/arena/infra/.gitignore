# Terraform state (contains secrets and resource details)
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# Build artifacts
.build/

# Crash logs
crash.log
crash.*.log

# Override files (used for local-only overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lambda dependencies (installed for tests, not deployed — AWS runtime includes them)
lambda/node_modules/
lambda/package-lock.json

# Lambda compiled output (built from src/ via tsc)
lambda/dist/
